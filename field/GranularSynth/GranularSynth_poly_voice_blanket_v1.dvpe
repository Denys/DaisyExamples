{
  "version": "1.0.0",
  "patch": {
    "metadata": {
      "name": "GranularSynth Poly Voice Blanket V1 Demo",
      "author": "OpenAI Codex",
      "description": "Loadable V1 codegen demo using a poly_voice_blanket directive around visible Grainlet voice-template blocks. Codegen clones the enclosed voice chain 8 times, scans Daisy Field keys, allocates notes, and sums stereo outputs into shared filters and reverb.",
      "created": "2026-05-15T00:00:00.000Z",
      "modified": "2026-05-15T00:00:00.000Z",
      "version": "1.0.0",
      "targetHardware": "field",
      "sampleRate": 48000,
      "blockSize": 48
    },
    "hardwareConfig": {
      "platform": "field",
      "pinMapping": {},
      "audioIOMapping": {
        "inputs": [],
        "outputs": []
      }
    },
    "blocks": [
      {
        "id": "knob_shape",
        "definitionId": "knob",
        "position": { "x": 60, "y": 60 },
        "parameterValues": { "channel": "0", "min": 0, "max": 1, "curve": "linear" },
        "label": "K1 Shape"
      },
      {
        "id": "knob_formant",
        "definitionId": "knob",
        "position": { "x": 60, "y": 150 },
        "parameterValues": { "channel": "1", "min": 120, "max": 6000, "curve": "exponential" },
        "label": "K2 Formant"
      },
      {
        "id": "knob_bleed",
        "definitionId": "knob",
        "position": { "x": 60, "y": 240 },
        "parameterValues": { "channel": "2", "min": 0, "max": 1, "curve": "linear" },
        "label": "K3 Bleed"
      },
      {
        "id": "knob_attack",
        "definitionId": "knob",
        "position": { "x": 60, "y": 330 },
        "parameterValues": { "channel": "3", "min": 0.001, "max": 1.25, "curve": "exponential" },
        "label": "K4 Attack"
      },
      {
        "id": "knob_release",
        "definitionId": "knob",
        "position": { "x": 60, "y": 420 },
        "parameterValues": { "channel": "4", "min": 0.02, "max": 2.5, "curve": "exponential" },
        "label": "K5 Release"
      },
      {
        "id": "knob_cutoff",
        "definitionId": "knob",
        "position": { "x": 60, "y": 560 },
        "parameterValues": { "channel": "5", "min": 180, "max": 12000, "curve": "exponential" },
        "label": "K6 Cutoff"
      },
      {
        "id": "knob_spread",
        "definitionId": "knob",
        "position": { "x": 60, "y": 510 },
        "parameterValues": { "channel": "6", "min": 0, "max": 1, "curve": "linear" },
        "label": "K7 Spread"
      },
      {
        "id": "knob_reverb",
        "definitionId": "knob",
        "position": { "x": 60, "y": 650 },
        "parameterValues": { "channel": "7", "min": 0, "max": 1, "curve": "linear" },
        "label": "K8 Reverb"
      },
      {
        "id": "voice_grain",
        "definitionId": "grainlet_oscillator",
        "position": { "x": 330, "y": 120 },
        "parameterValues": { "freq": 0, "formant_freq": 0, "shape": 0, "bleed": 0 },
        "enabledCvPorts": [ "freq", "formant_freq", "shape", "bleed" ],
        "label": "Voice Grainlet"
      },
      {
        "id": "voice_env",
        "definitionId": "adsr",
        "position": { "x": 330, "y": 330 },
        "parameterValues": { "attack": 0, "decay": 0.08, "sustain": 0.85, "release": 0 },
        "enabledCvPorts": [ "attack", "release" ],
        "label": "Voice Env"
      },
      {
        "id": "voice_vca",
        "definitionId": "vca",
        "position": { "x": 580, "y": 220 },
        "parameterValues": { "gain": 0.7 },
        "enabledCvPorts": [ "gain" ],
        "label": "Voice Amp"
      },
      {
        "id": "voice_pan",
        "definitionId": "pan",
        "position": { "x": 800, "y": 220 },
        "parameterValues": { "pan": 0.5 },
        "enabledCvPorts": [ "pan" ],
        "label": "Voice Spread Pan"
      },
      {
        "id": "filter_l",
        "definitionId": "svf",
        "position": { "x": 1080, "y": 150 },
        "parameterValues": { "freq": 0, "res": 0.35, "drive": 0.6 },
        "enabledCvPorts": [ "freq" ],
        "label": "Left Lowpass"
      },
      {
        "id": "filter_r",
        "definitionId": "svf",
        "position": { "x": 1080, "y": 340 },
        "parameterValues": { "freq": 0, "res": 0.35, "drive": 0.6 },
        "enabledCvPorts": [ "freq" ],
        "label": "Right Lowpass"
      },
      {
        "id": "rev1",
        "definitionId": "reverb_sc",
        "position": { "x": 1350, "y": 250 },
        "parameterValues": { "feedback": 0.8, "lpfreq": 8000, "wet_dry": 0 },
        "enabledCvPorts": [ "wet_dry" ],
        "label": "Reverb"
      },
      {
        "id": "out1",
        "definitionId": "audio_output",
        "position": { "x": 1600, "y": 270 },
        "parameterValues": {},
        "label": "Audio Out"
      }
    ],
    "connections": [
      { "id": "c_shape", "sourceBlockId": "knob_shape", "sourcePortId": "out", "targetBlockId": "voice_grain", "targetPortId": "shape_cv", "type": "cv" },
      { "id": "c_formant", "sourceBlockId": "knob_formant", "sourcePortId": "out", "targetBlockId": "voice_grain", "targetPortId": "formant_freq_cv", "type": "cv" },
      { "id": "c_bleed", "sourceBlockId": "knob_bleed", "sourcePortId": "out", "targetBlockId": "voice_grain", "targetPortId": "bleed_cv", "type": "cv" },
      { "id": "c_attack", "sourceBlockId": "knob_attack", "sourcePortId": "out", "targetBlockId": "voice_env", "targetPortId": "attack_cv", "type": "cv" },
      { "id": "c_release", "sourceBlockId": "knob_release", "sourcePortId": "out", "targetBlockId": "voice_env", "targetPortId": "release_cv", "type": "cv" },
      { "id": "c_spread", "sourceBlockId": "knob_spread", "sourcePortId": "out", "targetBlockId": "voice_pan", "targetPortId": "pan_cv", "type": "cv" },
      { "id": "c_grain_vca", "sourceBlockId": "voice_grain", "sourcePortId": "out", "targetBlockId": "voice_vca", "targetPortId": "in", "type": "audio" },
      { "id": "c_env_vca", "sourceBlockId": "voice_env", "sourcePortId": "out", "targetBlockId": "voice_vca", "targetPortId": "gain_cv", "type": "cv" },
      { "id": "c_vca_pan", "sourceBlockId": "voice_vca", "sourcePortId": "out", "targetBlockId": "voice_pan", "targetPortId": "in", "type": "audio" },
      { "id": "c_pan_l_filter", "sourceBlockId": "voice_pan", "sourcePortId": "left", "targetBlockId": "filter_l", "targetPortId": "in", "type": "audio" },
      { "id": "c_pan_r_filter", "sourceBlockId": "voice_pan", "sourcePortId": "right", "targetBlockId": "filter_r", "targetPortId": "in", "type": "audio" },
      { "id": "c_cutoff_l", "sourceBlockId": "knob_cutoff", "sourcePortId": "out", "targetBlockId": "filter_l", "targetPortId": "freq_cv", "type": "cv" },
      { "id": "c_cutoff_r", "sourceBlockId": "knob_cutoff", "sourcePortId": "out", "targetBlockId": "filter_r", "targetPortId": "freq_cv", "type": "cv" },
      { "id": "c_reverb", "sourceBlockId": "knob_reverb", "sourcePortId": "out", "targetBlockId": "rev1", "targetPortId": "wet_dry_cv", "type": "cv" },
      { "id": "c_filter_l_rev", "sourceBlockId": "filter_l", "sourcePortId": "low", "targetBlockId": "rev1", "targetPortId": "in_l", "type": "audio" },
      { "id": "c_filter_r_rev", "sourceBlockId": "filter_r", "sourcePortId": "low", "targetBlockId": "rev1", "targetPortId": "in_r", "type": "audio" },
      { "id": "c_rev_l_out", "sourceBlockId": "rev1", "sourcePortId": "out_l", "targetBlockId": "out1", "targetPortId": "left", "type": "audio" },
      { "id": "c_rev_r_out", "sourceBlockId": "rev1", "sourcePortId": "out_r", "targetBlockId": "out1", "targetPortId": "right", "type": "audio" }
    ],
    "polyVoiceBlankets": [
      {
        "id": "voice_blanket",
        "label": "Poly Voice Blanket V1",
        "position": { "x": 285, "y": 80 },
        "size": { "width": 720, "height": 420 },
        "voiceCount": 8,
        "octave": 2,
        "allocator": "reuse_free_oldest",
        "memberBlockIds": [ "voice_grain", "voice_env", "voice_vca", "voice_pan" ]
      }
    ]
  }
}
