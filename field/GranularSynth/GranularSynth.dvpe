{
  "version": "1.0.0",
  "patch": {
    "metadata": {
      "name": "GranularSynth Poly Block",
      "author": "OpenAI Codex",
      "description": "Compact DVPE representation of DaisyExamples/field/GranularSynth using one poly_grainlet_voice block for the Field keyboard allocator, shared stereo filtering, reverb, output, and K1-K8 macro controls.",
      "created": "2026-05-14T00:00:00.000Z",
      "modified": "2026-05-15T00:00:00.000Z",
      "version": "1.0.0",
      "targetHardware": "field",
      "sampleRate": 48000,
      "blockSize": 48
    },
    "hardwareConfig": {
      "platform": "field",
      "pinMapping": {},
      "audioIOMapping": {
        "inputs": [],
        "outputs": []
      }
    },
    "blocks": [
      {
        "id": "knob_shape",
        "definitionId": "knob",
        "position": { "x": 60, "y": 60 },
        "parameterValues": { "channel": "0", "min": 0, "max": 1, "curve": "linear" },
        "label": "K1 Shape"
      },
      {
        "id": "knob_formant",
        "definitionId": "knob",
        "position": { "x": 60, "y": 160 },
        "parameterValues": { "channel": "1", "min": 120, "max": 6000, "curve": "exponential" },
        "label": "K2 Formant"
      },
      {
        "id": "knob_bleed",
        "definitionId": "knob",
        "position": { "x": 60, "y": 260 },
        "parameterValues": { "channel": "2", "min": 0, "max": 1, "curve": "linear" },
        "label": "K3 Bleed"
      },
      {
        "id": "knob_attack",
        "definitionId": "knob",
        "position": { "x": 60, "y": 360 },
        "parameterValues": { "channel": "3", "min": 0.001, "max": 1.25, "curve": "exponential" },
        "label": "K4 Attack"
      },
      {
        "id": "knob_release",
        "definitionId": "knob",
        "position": { "x": 60, "y": 460 },
        "parameterValues": { "channel": "4", "min": 0.02, "max": 2.5, "curve": "exponential" },
        "label": "K5 Release"
      },
      {
        "id": "knob_cutoff",
        "definitionId": "knob",
        "position": { "x": 60, "y": 560 },
        "parameterValues": { "channel": "5", "min": 180, "max": 12000, "curve": "exponential" },
        "label": "K6 Cutoff"
      },
      {
        "id": "knob_spread",
        "definitionId": "knob",
        "position": { "x": 60, "y": 660 },
        "parameterValues": { "channel": "6", "min": 0, "max": 1, "curve": "linear" },
        "label": "K7 Spread"
      },
      {
        "id": "knob_reverb",
        "definitionId": "knob",
        "position": { "x": 60, "y": 760 },
        "parameterValues": { "channel": "7", "min": 0, "max": 1, "curve": "linear" },
        "label": "K8 Reverb"
      },
      {
        "id": "poly_voice",
        "definitionId": "poly_grainlet_voice",
        "position": { "x": 350, "y": 260 },
        "parameterValues": {
          "voice_count": 8,
          "octave": 2,
          "shape": 0,
          "formant_freq": 0,
          "bleed": 0,
          "attack": 0,
          "release": 0,
          "spread": 0,
          "output_gain": 0.18
        },
        "enabledCvPorts": [ "shape", "formant_freq", "bleed", "attack", "release", "spread" ],
        "label": "8 Voice Grainlet"
      },
      {
        "id": "lowpass_left",
        "definitionId": "svf",
        "position": { "x": 650, "y": 190 },
        "parameterValues": { "freq": 0, "res": 0.35, "drive": 0.6 },
        "enabledCvPorts": [ "freq" ],
        "label": "Left Lowpass"
      },
      {
        "id": "lowpass_right",
        "definitionId": "svf",
        "position": { "x": 650, "y": 370 },
        "parameterValues": { "freq": 0, "res": 0.35, "drive": 0.6 },
        "enabledCvPorts": [ "freq" ],
        "label": "Right Lowpass"
      },
      {
        "id": "reverb_sc",
        "definitionId": "reverb_sc",
        "position": { "x": 900, "y": 280 },
        "parameterValues": { "feedback": 0.8, "lpfreq": 8000, "wet_dry": 0 },
        "enabledCvPorts": [ "wet_dry" ],
        "label": "Reverb"
      },
      {
        "id": "main_output",
        "definitionId": "audio_output",
        "position": { "x": 1150, "y": 300 },
        "parameterValues": {},
        "label": "Audio Out"
      }
    ],
    "connections": [
      { "id": "c_shape_poly", "sourceBlockId": "knob_shape", "sourcePortId": "out", "targetBlockId": "poly_voice", "targetPortId": "shape_cv", "type": "cv" },
      { "id": "c_formant_poly", "sourceBlockId": "knob_formant", "sourcePortId": "out", "targetBlockId": "poly_voice", "targetPortId": "formant_freq_cv", "type": "cv" },
      { "id": "c_bleed_poly", "sourceBlockId": "knob_bleed", "sourcePortId": "out", "targetBlockId": "poly_voice", "targetPortId": "bleed_cv", "type": "cv" },
      { "id": "c_attack_poly", "sourceBlockId": "knob_attack", "sourcePortId": "out", "targetBlockId": "poly_voice", "targetPortId": "attack_cv", "type": "cv" },
      { "id": "c_release_poly", "sourceBlockId": "knob_release", "sourcePortId": "out", "targetBlockId": "poly_voice", "targetPortId": "release_cv", "type": "cv" },
      { "id": "c_spread_poly", "sourceBlockId": "knob_spread", "sourcePortId": "out", "targetBlockId": "poly_voice", "targetPortId": "spread_cv", "type": "cv" },
      { "id": "c_cutoff_left", "sourceBlockId": "knob_cutoff", "sourcePortId": "out", "targetBlockId": "lowpass_left", "targetPortId": "freq_cv", "type": "cv" },
      { "id": "c_cutoff_right", "sourceBlockId": "knob_cutoff", "sourcePortId": "out", "targetBlockId": "lowpass_right", "targetPortId": "freq_cv", "type": "cv" },
      { "id": "c_reverb_mix", "sourceBlockId": "knob_reverb", "sourcePortId": "out", "targetBlockId": "reverb_sc", "targetPortId": "wet_dry_cv", "type": "cv" },
      { "id": "c_poly_left_filter", "sourceBlockId": "poly_voice", "sourcePortId": "left", "targetBlockId": "lowpass_left", "targetPortId": "in", "type": "audio" },
      { "id": "c_poly_right_filter", "sourceBlockId": "poly_voice", "sourcePortId": "right", "targetBlockId": "lowpass_right", "targetPortId": "in", "type": "audio" },
      { "id": "c_left_filter_reverb", "sourceBlockId": "lowpass_left", "sourcePortId": "low", "targetBlockId": "reverb_sc", "targetPortId": "in_l", "type": "audio" },
      { "id": "c_right_filter_reverb", "sourceBlockId": "lowpass_right", "sourcePortId": "low", "targetBlockId": "reverb_sc", "targetPortId": "in_r", "type": "audio" },
      { "id": "c_reverb_left_out", "sourceBlockId": "reverb_sc", "sourcePortId": "out_l", "targetBlockId": "main_output", "targetPortId": "left", "type": "audio" },
      { "id": "c_reverb_right_out", "sourceBlockId": "reverb_sc", "sourcePortId": "out_r", "targetBlockId": "main_output", "targetPortId": "right", "type": "audio" }
    ]
  }
}
