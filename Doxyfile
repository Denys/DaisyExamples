PROJECT_NAME           = "DaisyPedal Reference"
PROJECT_BRIEF          = "DaisyPedal board integration, DSP modules, and example set for DaisyExamples"
PROJECT_NUMBER         = 0.1.0
OUTPUT_DIRECTORY       = build/docs/daisypedal
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = docs/daisypedal_reference_main.md

INPUT                  = docs/daisypedal_reference_main.md \
                         docs/daisypedal_groups.dox \
                         pedal/README.md \
                         pedal/PassthruBypass/README.md \
                         pedal/NoiseGate/README.md \
                         pedal/PitchDrop/README.md \
                         pedal/PolyOctave/README.md \
                         libDaisy/src/daisy_pedal.h \
                         DaisySP/Source/DaisyPedal
FILE_PATTERNS          = *.h *.md *.dox
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */.tmp/* */.worktrees/*

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
INTERNAL_DOCS          = NO
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
INLINE_SOURCES         = NO
SOURCE_BROWSER         = NO
VERBATIM_HEADERS       = NO

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = NO
DISABLE_INDEX          = NO

GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES
PDF_HYPERLINKS         = YES

HAVE_DOT               = NO
