{
  "version": "1.0.0",
  "patch": {
    "metadata": {
      "name": "Field Additive Synth",
      "author": "Antigravity",
      "description": "8-voice polyphonic additive synthesizer. HarmonicOscillator<16> per voice + ADSR, global LFO (vibrato/tremolo), Chorus, ReverbSc. SW1/SW2 dual knob pages, A-row spectral presets, B-row LFO wave + performance toggles. MIDI TRS, last-note stealing.",
      "created": "2026-03-05T21:42:00Z",
      "modified": "2026-03-05T20:50:19.395Z",
      "version": "1.0.0",
      "targetHardware": "field",
      "sampleRate": 48000,
      "blockSize": 48
    },
