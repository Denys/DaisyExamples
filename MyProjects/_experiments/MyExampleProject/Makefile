TARGET = ExampleProject

USE_DAISYSP_LGPL = 1

# Sources
CPP_SOURCES = ExampleProject.cpp

# Library Locations
LIBDAISY_DIR = ../../../libDaisy
DAISYSP_DIR = ../../../DaisySP

# Add HID path (for logger.h)
CPPFLAGS += -I$(LIBDAISY_DIR)/src/hid

# Core location, and generic Makefile.
SYSTEM_FILES_DIR = $(LIBDAISY_DIR)/core
include $(SYSTEM_FILES_DIR)/Makefile

